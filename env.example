# ============================================================
# Sendika Yönetim Paneli — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayarak .env olarak adlandırın ve doldurun.
# .env dosyasını asla repoya eklemeyin!
# ============================================================

# ---- Veritabanı ----
DATABASE_URL="postgresql://KULLANICI:SIFRE@localhost:5432/VERITABANI?schema=public"

# Docker Compose (docker-compose.yml) tarafından kullanılır
POSTGRES_DB=yonetim_paneli
POSTGRES_USER=postgres
POSTGRES_PASSWORD=GUCLU_BIR_SIFRE_KOYUN

# ---- JWT / Kimlik Doğrulama ----
# En az 64 karakterlik rastgele bir değer kullanın.
# Üretmek için: openssl rand -hex 32
JWT_SECRET=BURAYA_EN_AZ_64_KARAKTER_GUCLU_BIR_SECRET_KOYUN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- İlk Admin Kullanıcısı (seed için) ----
ADMIN_EMAIL=admin@kurumisiniz.org.tr
ADMIN_PASSWORD=GUCLU_BIR_SIFRE_KOYUN

# ---- Uygulama ----
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://panel.kurumisiniz.org.tr
CORS_CREDENTIALS=true

# ---- Redis (Cache + Brute-force Koruma) ----
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- AWS SES (E-posta) ----
# AWS Console → IAM → Kullanıcı → SES izinleri → Access Key
AWS_SES_REGION=eu-central-1
AWS_SES_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SES_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SES_FROM_EMAIL=bilgi@kurumisiniz.org.tr

# ---- NetGSM (SMS) ----
NETGSM_USERNAME=NETGSM_KULLANICI_ADINIZ
NETGSM_PASSWORD=NETGSM_SIFRENIZ
NETGSM_MSG_HEADER=MARKAISMINIZ
NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/get

# ---- WAHA (WhatsApp HTTP API) ----
# WAHA Dashboard: http://SUNUCU_IP:3001/dashboard
WAHA_API_URL=http://localhost:3001
WAHA_API_KEY=GUCLU_BIR_WAHA_KEY_KOYUN
WAHA_SESSION_NAME=default
WAHA_WEBHOOK_URL=http://localhost:3000
WAHA_WEBHOOK_SECRET=GUCLU_BIR_WEBHOOK_SECRET_KOYUN
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=GUCLU_BIR_SIFRE_KOYUN
WHATSAPP_ENABLED=true
NOTIFICATION_WHATSAPP_ENABLED=true

# ---- Frontend (Vite Build) ----
# Production'da genellikle /api (reverse proxy üzerinden)
VITE_API_BASE_URL=/api

# ---- Üyelik Sorgulama Güvenlik Token ----
# Dışarıya açık üyelik sorgulama endpoint'ini korur
MEMBERSHIP_INQUIRY_TOKEN=

# ---- Docker Compose Build Ayarları ----
# VPS'te Prisma engine indirmesi yavaşsa mirror kullanın (genellikle boş bırakın)
PRISMA_ENGINES_MIRROR=
